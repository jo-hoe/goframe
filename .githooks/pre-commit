#!/bin/sh
# Pre-commit hook:
#   1. Runs go fmt on staged Go files.
#   2. If operator API types are staged, checks that generated files are up to date.

set -e

# Ensure Go is available
if ! command -v go >/dev/null 2>&1; then
  echo "[pre-commit] 'go' not found, skipping checks"
  exit 0
fi

# Collect staged .go files (Added, Copied, Modified)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.go$' || true)

# --- go fmt ---
if [ -n "$STAGED_GO_FILES" ]; then
  echo "[pre-commit] Running go fmt on staged Go files..."

  echo "$STAGED_GO_FILES" | while IFS= read -r file; do
    [ -f "$file" ] || continue
    gofmt -s -w "$file"
  done

  echo "$STAGED_GO_FILES" | while IFS= read -r file; do
    [ -f "$file" ] || continue
    git add "$file"
  done

  UNFORMATTED=$(echo "$STAGED_GO_FILES" | while IFS= read -r file; do
    [ -f "$file" ] || continue
    gofmt -l "$file"
  done)

  if [ -n "$UNFORMATTED" ]; then
    echo "[pre-commit] Error: some files remain unformatted:"
    echo "$UNFORMATTED"
    echo "[pre-commit] Please run: gofmt -s -w (files above) and commit again."
    exit 1
  fi

  echo "[pre-commit] go fmt complete."
fi

# --- generate-check ---
# Run when operator API types or existing generated files are staged.
OPERATOR_TYPES_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'internal/operator/api/v1alpha1/.*\.go$' || true)

if [ -n "$OPERATOR_TYPES_STAGED" ]; then
  echo "[pre-commit] Operator API types changed — checking generated files..."
  if ! make generate-check; then
    echo "[pre-commit] Error: generated files are out of sync."
    echo "[pre-commit] Run 'make generate', review the diff, and stage the updated files."
    exit 1
  fi
  # Re-stage any files updated by make generate
  git add internal/operator/api/v1alpha1/zz_generated.deepcopy.go \
          charts/goframe-operator/templates/_goframes.yaml 2>/dev/null || true
  echo "[pre-commit] Generated files are up to date."
fi

echo "[pre-commit] Checks complete. Proceeding with commit."
exit 0